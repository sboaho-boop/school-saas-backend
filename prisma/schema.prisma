generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("co-admin")
  createdAt DateTime @default(now())

  feedbacks Feedback[]
}

model Feedback {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String
  userName   String
  userEmail  String
  schoolName String
  subject    String
  message    String
  status     String   @default("open")
  repliedAt  DateTime?
  reply      String?
  createdAt  DateTime @default(now())

  school      School      @relation(fields: [schoolId], references: [id])
  assignedTo  SuperAdmin? @relation(fields: [assignedToId], references: [id])
  assignedToId String?
}

model School {
  id           String   @id @default(cuid())
  code         String?  @unique
  name         String
  address      String   @default("")
  pinThreshold  Float    @default(20)
  hubtelClientId     String? @default("")
  hubtelClientSecret String? @default("")
  hubtelMerchantAccount String? @default("")
  hubtelDisbursementAccount String? @default("")
  hubtelSmsClientId     String? @default("")
  hubtelSmsClientSecret String? @default("")
  createdAt    DateTime @default(now())

  users          User[]
  students       Student[]
  staff          Staff[]
  campuses       Campus[]
  feeRecords     FeeRecord[]
  transportRoutes TransportRoute[]
  tasks          Task[]
  taskComments   TaskComment[]
  academicClasses AcademicClass[]
  subjects       Subject[]
  terms          Term[]
  attendances      Attendance[]
  staffAttendances StaffAttendance[]
  grades         Grade[]
  messages       Message[]
  announcements  Announcement[]
  subscriptions  Subscription[]
  auditLogs      AuditLog[]
  wallets        StudentWallet[]
  transactions   Transaction[]
  notifications  Notification[]
  cardOrders     CardOrder[]
  studentReports StudentReport[]
  privacyConsents PrivacyConsent[]
  assignments     Assignment[]
  submissions     Submission[]
  timetableSlots  TimetableSlot[]
  exams           Exam[]
  questions       Question[]
  examSubmissions ExamSubmission[]
  incidents       Incident[]
  books           Book[]
  bookLoans       BookLoan[]
  hostels         Hostel[]
  rooms           Room[]
  bedAllocations  BedAllocation[]
  conferenceSlots ConferenceSlot[]
  conferenceBookings ConferenceBooking[]
  campaigns       Campaign[]
  lessonPlans     LessonPlan[]
  inventoryItems  InventoryItem[]
  inventoryAssignments InventoryAssignment[]
  alumni          Alumni[]
  driverTrips     DriverTrip[]
  calendarEvents  CalendarEvent[]
  feedbacks       Feedback[]
  aiConversations AIConversation[]
  directDebitPreapprovals DirectDebitPreapproval[]
  recurringInvoices RecurringInvoice[]
}

model User {
  id               String    @id @default(cuid())
  schoolId         String
  campusId         String?
  email            String
  password         String
  name             String
  role             String    @default("admin")
  phone            String    @default("")
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  isVerified       Boolean   @default(false)
  verificationCode String?
  verificationExpiry DateTime?
  smsPreferences   String    @default("{}")
  createdAt        DateTime  @default(now())

  school         School          @relation(fields: [schoolId], references: [id])
  campus         Campus?         @relation("CampusUsers", fields: [campusId], references: [id])
  headTeacherFor Campus?         @relation("CampusHeadTeacher")
  tasksCreated   Task[]          @relation("AssignedBy")
  tasksAssigned  Task[]          @relation("AssignedTo")
  messagesSent   Message[]       @relation("FromUser")
  messagesRecv   Message[]       @relation("ToUser")
  announcements  Announcement[]
  notifications  Notification[]
  conferenceSlots ConferenceSlot[]

  @@unique([schoolId, email])
}

model Campus {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  code        String
  address     String   @default("")
  headTeacherId String? @unique
  createdAt   DateTime @default(now())

  school      School  @relation(fields: [schoolId], references: [id])
  headTeacher User?   @relation("CampusHeadTeacher", fields: [headTeacherId], references: [id])
  users       User[]  @relation("CampusUsers")
  staff       Staff[]

  @@unique([schoolId, code])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model Student {
  id             String   @id @default(cuid())
  schoolId       String
  indexNumber    String?
  firstName      String
  lastName       String
  email          String
  password       String?
  classId        String
  className      String
  dateOfBirth    String
  gender         String   @default("male")
  photoUrl       String?
  parentName     String
  parentPhone    String
  parentEmail    String
  parentPassword String?
  enrollmentDate String
  status         String   @default("active")
  createdAt      DateTime @default(now())

  school          School          @relation(fields: [schoolId], references: [id])
  feeRecords      FeeRecord[]
  attendanceRecs  Attendance[]
  grades          Grade[]
  wallet          StudentWallet?
  reports         StudentReport[]
  submissions     Submission[]
  examSubmissions ExamSubmission[]
  incidents       Incident[]
  bedAllocations  BedAllocation[]
  conferenceBookings ConferenceBooking[]
  alumni          Alumni?

  @@unique([schoolId, email])
  @@unique([schoolId, indexNumber])
}

model Staff {
  id               String   @id @default(cuid())
  schoolId         String
  indexNumber      String?
  campusId         String?
  name             String
  email            String
  phone            String
  role             String
  department       String
  staffType        String
  assignedClass    String?
  assignedSubjects String   @default("[]")
  assignedRouteId  String?
  assignedRouteName String?
  bankAccountNumber String?
  bankAccountName   String?
  bankCode          String?
  bankName          String?
  cardUid          String?
  wristbandUid     String?
  status           String   @default("active")
  hireDate         String
  createdAt        DateTime @default(now())

  school          School             @relation(fields: [schoolId], references: [id])
  campus          Campus?            @relation(fields: [campusId], references: [id])
  assignedRoutes  TransportRoute[]   @relation("RouteDrivers")
  driverTrips     DriverTrip[]
  attendanceRecs  StaffAttendance[]

  @@unique([schoolId, email])
  @@unique([schoolId, cardUid])
  @@unique([schoolId, wristbandUid])
  @@unique([schoolId, indexNumber])
}

model FeeRecord {
  id          String @id @default(cuid())
  schoolId    String
  studentId   String
  studentName String
  amount      Float
  paid        Float  @default(0)
  balance     Float  @default(0)
  dueDate     String
  status      String @default("unpaid")

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model TransportRoute {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String
  stops       String   @default("[]")
  driverName  String
  driverPhone String
  capacity    Int
  status      String   @default("active")
  createdAt   DateTime @default(now())

  school  School     @relation(fields: [schoolId], references: [id])
  drivers Staff[]    @relation("RouteDrivers")
  trips   DriverTrip[]
}

model DriverTrip {
  id            String   @id @default(cuid())
  schoolId      String
  routeId       String
  staffId       String
  status        String   @default("checked_in")
  checkInTime   DateTime @default(now())
  departureTime DateTime?
  arrivalTime   DateTime?
  completedAt   DateTime?
  date          String
  notes         String   @default("")

  school School         @relation(fields: [schoolId], references: [id])
  route  TransportRoute @relation(fields: [routeId], references: [id])
  driver Staff          @relation(fields: [staffId], references: [id])

  @@unique([schoolId, staffId, date])
}

model Task {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String
  assignedTo  String
  assignedBy  String
  status      String   @default("pending")
  priority    String   @default("medium")
  dueDate     String
  attachments String   @default("[]")
  createdAt   DateTime @default(now())

  school   School        @relation(fields: [schoolId], references: [id])
  assignee  User         @relation("AssignedTo", fields: [assignedTo], references: [id])
  assigner  User         @relation("AssignedBy", fields: [assignedBy], references: [id])
  comments  TaskComment[]
}

model TaskComment {
  id        String   @id @default(cuid())
  schoolId  String
  taskId    String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  task   Task   @relation(fields: [taskId], references: [id])
}

model AcademicClass {
  id       String @id @default(cuid())
  schoolId String
  name     String
  section  String
  students Int    @default(0)
  teacher  String @default("Unassigned")

  school   School    @relation(fields: [schoolId], references: [id])
  subjects Subject[]
}

model Subject {
  id       String @id @default(cuid())
  schoolId String
  name     String
  code     String
  teacher  String @default("Unassigned")
  classId  String

  school School        @relation(fields: [schoolId], references: [id])
  class  AcademicClass @relation(fields: [classId], references: [id])
}

model Term {
  id           String @id @default(cuid())
  schoolId     String
  name         String
  academicYear String
  startDate    String
  endDate      String
  isActive     Boolean @default(false)

  school School @relation(fields: [schoolId], references: [id])
}

model Attendance {
  id          String @id @default(cuid())
  schoolId    String
  studentId   String
  studentName String
  classId     String
  className   String
  date        String
  status      String @default("present")

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model StaffAttendance {
  id        String   @id @default(cuid())
  schoolId  String
  staffId   String
  staffName String
  date      String
  status    String   @default("present")
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

model Grade {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  subjectId  String
  classId    String
  termId     String
  score      Float
  grade      String   @default("")
  components String   @default("{}")
  remarks    String   @default("")
  createdAt  DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  schoolId  String
  subject   String
  body      String
  fromId    String
  toId      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  school   School @relation(fields: [schoolId], references: [id])
  sender   User   @relation("FromUser", fields: [fromId], references: [id])
  receiver User   @relation("ToUser", fields: [toId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  schoolId  String
  title     String
  body      String
  authorId  String
  priority  String   @default("normal")
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  author User   @relation(fields: [authorId], references: [id])
}

model Subscription {
  id            String   @id @default(cuid())
  schoolId      String   @unique
  plan          String   @default("free")
  status        String   @default("active")
  studentLimit  Int      @default(100)
  staffLimit    Int      @default(10)
  pendingPlan   String?
  pendingCheckoutRef String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  userId     String
  userName   String
  action     String
  resource   String
  resourceId String
  details    String   @default("")
  createdAt  DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model StudentWallet {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String   @unique
  studentName     String
  balance         Float    @default(0)
  totalSpent      Float    @default(0)
  cardUid         String?
  wristbandUid    String?
  transactionPin  String?
  dailyLimit      Float    @default(0)
  todaySpent      Float    @default(0)
  lastSpentReset  String   @default("")
  frozen          Boolean  @default(false)
  pendingTopupRef String?
  pendingTopupAmount Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  school       School        @relation(fields: [schoolId], references: [id])
  student      Student       @relation(fields: [studentId], references: [id])
  transactions Transaction[]

  @@unique([schoolId, cardUid])
  @@unique([schoolId, wristbandUid])
}

model Transaction {
  id          String   @id @default(cuid())
  schoolId    String
  walletId    String
  type        String
  amount      Float
  balanceAfter Float
  method      String   @default("card")
  service     String   @default("")
  terminalId  String   @default("")
  reference   String   @default("")
  createdAt   DateTime @default(now())

  school School        @relation(fields: [schoolId], references: [id])
  wallet StudentWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model CardOrder {
  id          String   @id @default(cuid())
  schoolId    String
  schoolName  String
  studentIds  String
  quantity    Int
  status      String   @default("pending")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model PushSubscription {
  id           String @id @default(cuid())
  userId       String
  schoolId     String
  endpoint     String @unique
  auth         String
  p256dh       String
  createdAt    DateTime @default(now())

  @@unique([userId, endpoint])
}

model StudentReport {
  id        String   @id @default(cuid())
  studentId String
  schoolId  String
  title     String
  content   String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  school School @relation(fields: [schoolId], references: [id])
}

// === NEW FEATURES ===

model Exam {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String
  subjectId   String
  title       String
  description String   @default("")
  duration    Int
  totalPoints Float    @default(0)
  passScore   Float    @default(0)
  dueDate     String
  createdBy   String
  createdAt   DateTime @default(now())

  school      School           @relation(fields: [schoolId], references: [id])
  questions   Question[]
  submissions ExamSubmission[]
}

model Question {
  id            String  @id @default(cuid())
  examId        String
  schoolId      String
  type          String  @default("mcq")
  questionText  String
  options       String  @default("[]")
  correctAnswer String  @default("")
  points        Float   @default(1)

  school School @relation(fields: [schoolId], references: [id])
  exam   Exam   @relation(fields: [examId], references: [id])
}

model ExamSubmission {
  id          String   @id @default(cuid())
  examId      String
  studentId   String
  schoolId    String
  answers     String   @default("{}")
  score       Float?
  grade       String   @default("")
  graded      Boolean  @default(false)
  feedback    String   @default("")
  submittedAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
}

model Incident {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  reportedBy  String
  type        String
  description String
  location    String   @default("")
  date        String
  action      String   @default("warning")
  status      String   @default("open")
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model Book {
  id               String   @id @default(cuid())
  schoolId         String
  title            String
  author           String
  isbn             String   @default("")
  publisher        String   @default("")
  category         String   @default("")
  quantity         Int      @default(1)
  availableQuantity Int     @default(1)
  shelfLocation    String   @default("")
  createdAt        DateTime @default(now())

  school  School     @relation(fields: [schoolId], references: [id])
  loans   BookLoan[]
}

model BookLoan {
  id           String    @id @default(cuid())
  schoolId     String
  bookId       String
  borrowedBy   String
  borrowedType String    @default("student")
  borrowedDate String
  dueDate      String
  returnedDate String?
  status       String    @default("active")
  fine         Float     @default(0)

  school School @relation(fields: [schoolId], references: [id])
  book   Book   @relation(fields: [bookId], references: [id])
}

model Hostel {
  id       String @id @default(cuid())
  schoolId String
  name     String
  gender   String @default("mixed")
  warden   String @default("")
  capacity Int    @default(0)

  school School @relation(fields: [schoolId], references: [id])
  rooms  Room[]
}

model Room {
  id        String @id @default(cuid())
  hostelId  String
  schoolId  String
  roomNumber String
  capacity  Int    @default(0)
  gender    String @default("mixed")

  school       School          @relation(fields: [schoolId], references: [id])
  hostel       Hostel          @relation(fields: [hostelId], references: [id])
  allocations  BedAllocation[]
}

model BedAllocation {
  id        String   @id @default(cuid())
  roomId    String
  studentId String
  schoolId  String
  bedNumber String   @default("")
  startDate String
  endDate   String?
  status    String   @default("active")

  school  School  @relation(fields: [schoolId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model ConferenceSlot {
  id         String @id @default(cuid())
  schoolId   String
  teacherId  String
  date       String
  startTime  String
  endTime    String
  maxParents Int    @default(5)
  bookedCount Int   @default(0)

  school   School             @relation(fields: [schoolId], references: [id])
  teacher  User               @relation(fields: [teacherId], references: [id])
  bookings ConferenceBooking[]
}

model ConferenceBooking {
  id          String   @id @default(cuid())
  slotId      String
  studentId   String
  schoolId    String
  parentEmail String
  notes       String   @default("")
  status      String   @default("booked")
  createdAt   DateTime @default(now())

  school School           @relation(fields: [schoolId], references: [id])
  slot   ConferenceSlot   @relation(fields: [slotId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String   @default("")
  date        String
  endDate     String?
  time        String?
  endTime     String?
  type        String   @default("event")
  color       String   @default("#3b82f6")
  allDay      Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}

model Campaign {
  id            String   @id @default(cuid())
  schoolId      String
  title         String
  message       String
  type          String   @default("sms")
  recipientType String   @default("all_parents")
  recipientFilter String @default("{}")
  sentCount     Int      @default(0)
  createdAt     DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model LessonPlan {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String
  subjectId   String
  teacherId   String
  week        String
  topic       String
  objectives  String
  materials   String   @default("")
  activities  String   @default("")
  assessment  String   @default("")
  status      String   @default("draft")
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model InventoryItem {
  id            String   @id @default(cuid())
  schoolId      String
  name          String
  category      String   @default("")
  quantity      Int      @default(0)
  condition     String   @default("good")
  location      String   @default("")
  purchaseDate  String?
  purchasePrice Float    @default(0)
  status        String   @default("available")
  createdAt     DateTime @default(now())

  school       School                @relation(fields: [schoolId], references: [id])
  assignments  InventoryAssignment[]
}

model InventoryAssignment {
  id           String   @id @default(cuid())
  itemId       String
  schoolId     String
  assignedTo   String
  assignedType String   @default("staff")
  assignedById String
  assignedDate String
  returnDate   String?
  notes        String   @default("")

  school School         @relation(fields: [schoolId], references: [id])
  item   InventoryItem  @relation(fields: [itemId], references: [id])
}

model Alumni {
  id               String   @id @default(cuid())
  schoolId         String
  studentId        String   @unique
  graduationYear   String
  currentOccupation String  @default("")
  phone            String   @default("")
  email            String   @default("")
  address          String   @default("")
  socialLinks      String   @default("{}")
  createdAt        DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
}

model TimetableSlot {
  id        String  @id @default(cuid())
  schoolId  String
  classId   String
  dayOfWeek Int
  startTime String
  endTime   String
  subjectId String?
  staffId   String?
  room      String  @default("")

  school School @relation(fields: [schoolId], references: [id])
}

model Assignment {
  id          String   @id @default(cuid())
  schoolId    String
  classId     String
  subjectId   String?
  title       String
  description String
  dueDate     String
  totalPoints Float    @default(100)
  fileUrl     String?
  createdBy   String
  createdAt   DateTime @default(now())

  school      School       @relation(fields: [schoolId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String   @id @default(cuid())
  schoolId     String
  assignmentId String
  studentId    String
  content      String   @default("")
  fileUrl      String?
  status       String   @default("submitted")
  grade        Float?
  feedback     String?
  gradedBy     String?
  gradedAt     DateTime?
  submittedAt  DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model PrivacyConsent {
  id      String @id @default(cuid())
  schoolId String
  school  School @relation(fields: [schoolId], references: [id])
}

model AIConversation {
  id          String   @id @default(cuid())
  schoolId    String
  userId      String
  userMessage String
  aiResponse  String
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model DirectDebitPreapproval {
  id                    String   @id @default(cuid())
  schoolId              String
  studentId             String?
  phone                 String
  channel               String
  hubtelPreApprovalId   String?
  clientReferenceId     String
  verificationType      String?
  preapprovalStatus     String   @default("PENDING")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, phone])
}

model RecurringInvoice {
  id                    String   @id @default(cuid())
  schoolId              String
  studentId             String?
  phone                 String
  channel               String
  recurringInvoiceId    String?
  requestId             String?
  description           String
  paymentInterval       String
  recurringAmount       Float
  initialAmount         Float
  startTime             String
  orderDate             String
  invoiceEndDate        String
  status                String   @default("PENDING")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])
}
